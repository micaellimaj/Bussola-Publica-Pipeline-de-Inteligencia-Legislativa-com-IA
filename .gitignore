# =============================================================================
# Bussola Publica - .gitignore
# =============================================================================

# --- Segredos / ambiente (NUNCA versionar) ---
.env
*.env
!.env.example
# .env em qualquer subpasta (ex.: 05_automacao_ia/docker/.env)
**/.env

# --- Ambiente Python ---
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# --- Dados gerados pelo pipeline (brutos e processados) ---
data/
*.log

# --- Sistema operacional ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editores / IDEs ---
.vscode/
.idea/

# --- Node (gerador da apresentacao) ---
node_modules/

# --- Docker local (volumes sao externos; nada a versionar) ---
