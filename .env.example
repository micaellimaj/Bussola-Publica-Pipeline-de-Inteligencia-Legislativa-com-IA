# =============================================================================
# Bussola Publica - variaveis do n8n (Docker)
# Copie para .env (na mesma pasta docker/) e preencha.
#   Windows PowerShell:  Copy-Item .env.example .env
# NUNCA suba este .env para o GitHub.
# =============================================================================

# Login que o n8n vai pedir ao abrir http://localhost:5678
N8N_USER=admin
N8N_PASSWORD=troque-esta-senha

# Chave de criptografia das credenciais salvas no n8n.
# Gere uma aleatoria e NAO mude depois de criar credenciais (senao elas quebram).
# Pode gerar com: python -c "import secrets; print(secrets.token_hex(24))"
N8N_ENCRYPTION_KEY=cole-aqui-uma-chave-aleatoria-longa

# Caminho da pasta do seu repositorio clonado (a que tem main.py e pyproject.toml).
# Use barras normais. Ex.: C:/Users/voce/Projetos/Bussola-Publica
# O script 2_subir_n8n.ps1 preenche isso automaticamente.
REPO_PATH=C:/caminho/para/Bussola-Publica
