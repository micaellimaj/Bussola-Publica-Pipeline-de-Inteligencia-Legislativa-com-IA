# =============================================================================
# BUSSOLA PUBLICA - Variaveis de Ambiente
# =============================================================================
# INSTRUCOES:
#   1. Copie este arquivo para .env  (cp .env.example .env)
#   2. Preencha os valores abaixo com suas credenciais reais
#   3. NUNCA suba o .env para o GitHub (ele ja esta no .gitignore)
# =============================================================================

# --- PostgreSQL (Supabase / Neon / Railway) ---
# Supabase: Settings > Database > Connection string > URI
# Formato : postgresql://postgres:[SENHA]@[HOST]:5432/postgres
DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# --- OpenAI API ---
# Obtenha em: https://platform.openai.com/api-keys
# Clique em "Create new secret key" — copie a chave (comeca com sk-proj-)
# Custo estimado para o desafio: < $0.10 USD no total
OPENAI_API_KEY=sk-proj-SUA_CHAVE_AQUI

# --- Configuracoes do Pipeline de IA (Etapas 4 e 5) ---
# DRY_RUN=true  -> apenas estima custo, nao chama a API nem grava no banco
# DRY_RUN=false -> executa de verdade
DRY_RUN=true

# Quantas proposicoes processar por execucao
# Recomendado: comece com 10 para testar, depois aumente
BATCH_SIZE=10

# Modelo OpenAI a usar para o resumo executivo (Etapa 4)
# gpt-4o-mini -> recomendado para o desafio (10x mais barato, qualidade otima para resumos)
# gpt-4o      -> melhor qualidade, mais caro
MODELO_IA=gpt-4o-mini

# --- Classificacao Tematica por Embeddings (Etapa 5 - Caminho A) ---
# Modelo de embedding usado para calcular a similaridade de cosseno entre a
# ementa da proposicao e cada tema (Tecnologia, Tributario, Saude, etc.)
# text-embedding-3-small -> recomendado (barato, ~$0.00002 / 1K tokens)
MODELO_EMBEDDING=text-embedding-3-small

# Limiar minimo de similaridade de cosseno (0 a 1) para aceitar a
# classificacao de um tema. Abaixo desse valor, a proposicao recebe o
# tema padrao "Outros".
LIMIAR_TEMA=0.20
